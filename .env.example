# --- Aiven Kafka Configuration ---
# You can get these from your Aiven Console
KAFKA_SERVICE_URI="your-kafka-uri:port"

# --- LangChain / LangSmith Tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langsmith-api-key"
LANGCHAIN_PROJECT="autonomous-forensics-agent"

# --- LLM Settings ---
# Ensure these models are pulled in Ollama
REASONING_MODEL="qwen3-vl:2b-instruct"
VISION_MODEL="qwen3-vl:2b-instruct"
